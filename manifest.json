{
  "manifest_version": 3,
  "name": "GreenLuma Manager",
  "version": "1.0.0",
  "description": "A browser extension for managing GreenLuma features.",
  "action": {
    "default_popup": "index.html",
    "default_title": "GreenLuma Manager"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "https://api.steampowered.com/*",
    "https://store.steampowered.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [],
  "web_accessible_resources": [
    {
      "resources": ["main.js", "styles.css", "search.js", "app-sort.js", "utils.js", "generator.js"],
      "matches": ["<all_urls>"]
    }
  ]
}